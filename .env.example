# Database Configuration (can also be set via Settings UI)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password

# AI Provider API Keys (can also be set via Settings UI)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# Default AI Provider (openai | anthropic | perplexity)
DEFAULT_AI_PROVIDER=anthropic
